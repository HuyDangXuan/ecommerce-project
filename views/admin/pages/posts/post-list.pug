          // end card-header
          form.input-group.mb-3(form-search)
            input.form-control(
              placeholder="Tìm kiếm bài viết..." 
              type="text"
              name="keyword"
              )
            button.btn.btn-secondary Tìm kiếm
          .card-body.pt-0
            .table-responsive
              table.table.mb-0.checkbox-all(id="datatable_1")
                thead.table-light
                  tr
                    th(style="width: 16px;")
                      .form-check.mb-0
                        input#select-all.form-check-input(
                          name="select-all" 
                          type="checkbox"
                          )
                    th.ps-0 STT
                    th Tên bài viết
                    th Danh mục cha
                    th Trạng thái
                    th Lượt xem
                    th.text-end Hành động
                tbody
                  each post, index in (posts || [])
                    tr
                      td
                        .form-check.mb-0
                          input.form-check-input(
                            name="select-item" 
                            type="checkbox"
                            )
                      td #{index + 1}
                      td #{post && post.name ? post.name : 'Không có'}
                      td #{post && post.parentName ? post.parentName : 'Không có'}
                      td
                        if post && post.status === 'active'
                          span.badge.bg-success.text-white Hoạt động
                        else if post && post.status === 'inactive'
                          span.badge.bg-danger.text-white Dừng hoạt động
                        else
                          span.badge.bg-light.text-dark Không xác định
                      td #{post && typeof post.views !== 'undefined' ? post.views : 0}
                      td.text-end
                        if post && post._id
                          a.btn.btn-sm.btn-primary.me-1(href=`/admin/posts/post-edit/${post._id}`)
                            i.fa-solid.fa-pen-to-square
                          a.btn.btn-sm.btn-danger(
                            href=`javascript:;`
                            button-api
                            data-method="PATCH"
                            data-api=`/${pathAdmin}/posts/post-delete/${post._id}`
                            )
                            i.fa-solid.fa-trash
      // end col