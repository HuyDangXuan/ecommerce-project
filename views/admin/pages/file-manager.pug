extends ../layouts/default.pug
include ../mixins/pagination.pug

block main
  //- Breadcrumbs
  ul.list-group.list-group-horizontal-md.mb-3(breadcrumb-folder)
  //- End Breadcrumbs

  //- Danh sách thư mục
  .card
    .card-header
      .row.align-items-center
        .col-lg-8
          h4.card-title Danh sách thư mục
        .col-lg-4
          form(form-create-folder)
            .input-group
              input.form-control(
                placeholder="Tên thư mục" 
                type="text"
                name="folderName"
                )
              button.btn.btn-secondary Tạo thư mục
    .card-header
      .card-body.pt-0
        .table-responsive
          table.table.table-striped.mb-0
            thead.table-light
              tr
                th Tên thư mục
                th Ngày tạo
                th.text-end Hành động
            tbody
              each item in listFolder
                tr
                  td 
                    a(
                      href="javascript:;"
                      button-open-folder
                      data-folder-path=item.name
                      )
                      .d-inline-flex.justify-content-center.align-items-center.thumb-md.bg-blue-subtle.rounded.mx-auto.me-1(bis_skin_checked="1")
                        i.fa-solid.fa-folder.fs-18.align-self-center.mb-0.text-blue
                      span #{item.name}
                  td #{item.createdAtFormatted}
                  td.text-end
                    a(
                      href="javascript:;"
                      button-delete-folder
                      folderId=`${item._id}`
                      folderName=`${item.name}`
                      )
                      i.las.la-trash-alt.text-secondary.fs-18.ms-1
  //- Hết Danh sách thư mục

  //- Danh sách file
  .card
    .card-header
      .row.align-items-center
        .col
          h4.card-title Danh sách file
        // end col
      // end row
    // end card-header
    .card-body.pt-0
      form.input-group.mb-3(form-search)
        input.form-control(
          placeholder="Tìm kiếm file..." 
          type="text"
          name="keyword"
          )
        button.btn.btn-secondary Tìm kiếm
      .table-responsive
        table.table.table-striped.mb-0
          thead.table-light
            tr
              th Tên
              th Ngày tạo
              th Kích thước
              th.text-end Hành động
          tbody
            each item in media
              tr
                td
                  if (item.mimetype.includes('image'))
                    img(
                      src=`${domainCDN}${item.folder}/${item.filename}`,
                      class="rounded thumb-md me-1 d-inline"
                    )
                  else if (item.mimetype.includes('video'))
                    .d-inline-flex.justify-content-center.align-items-center.thumb-md.bg-blue-subtle.rounded.mx-auto.me-1(bis_skin_checked="1")
                      i.fa-solid.fa-file-video.fs-18.align-self-center.mb-0.text-blue
                  else if (item.mimetype.includes('pdf'))
                    .d-inline-flex.justify-content-center.align-items-center.thumb-md.bg-blue-subtle.rounded.mx-auto.me-1(bis_skin_checked="1")
                      i.fa-solid.fa-file-pdf.fs-18.align-self-center.mb-0.text-blue
                  else
                    .d-inline-flex.justify-content-center.align-items-center.thumb-md.bg-blue-subtle.rounded.mx-auto.me-1(bis_skin_checked="1")
                      i.fa-solid.fa-microphone.fs-18.align-self-center.mb-0.text-blue
                  span #{item.filename}
                td #{item.createdAtFormatted}
                td #{item.sizeFormatted}
                td.text-end
                  a(
                    href="javascript:;"
                    button-copy
                    data-content=`${item.folder}/${item.filename}`
                    )
                    i.las.la-copy.text-secondary.fs-18.ms-1
                  a(
                    href="javascript:;"
                    data-bs-toggle="modal" 
                    data-bs-target="#modalPreviewFile"
                    button-preview-file
                    data-file=`${domainCDN}${item.folder}/${item.filename}`
                    data-mimetype=`${item.mimetype}`
                    )
                    i.las.la-eye.text-secondary.fs-18.ms-1
                  a(
                    href=`${domainCDN}${item.folder}/${item.filename}?type=download`
                    )
                    i.las.la-download.text-secondary.fs-18.ms-1
                  a(
                    href="javascript:;"
                    data-bs-toggle="modal" 
                    data-bs-target="#modalChangeFileName"
                    button-change-file-name
                    fileId=`${item._id}`
                    fileName=`${item.filename}`
                    )
                    i.las.la-pen.text-secondary.fs-18.ms-1
                  a(
                    href="javascript:;"
                    button-delete-file
                    fileId=`${item._id}`
                    fileName=`${item.filename}`
                    )
                    i.las.la-trash-alt.text-secondary.fs-18.ms-1
      +pagination()
  //- Hết danh sách file
  #modalPreviewFile.modal.fade.bd-example-modal-lg(
    aria-hidden="true" 
    role="dialog" 
    tabindex="-1"
    )
    .modal-dialog.modal-lg(role="document")
      .modal-content
        .modal-header
          h6.modal-title.m-0 Xem trước file
          button.btn-close(
            aria-label="Close" 
            data-bs-dismiss="modal" 
            type="button"
            )
        // end modal-header
        .modal-body
          .inner-preview
          
  #modalChangeFileName.modal.fade.bd-example-modal-lg(
    aria-hidden="true" 
    role="dialog" 
    tabindex="-1"
    )
    .modal-dialog.modal-lg(role="document")
      .modal-content
        .modal-header
          h6.modal-title.m-0 Thay đổi tên file
          button.btn-close(
            aria-label="Close" 
            data-bs-dismiss="modal" 
            type="button"
            )
        // end modal-header
        .modal-body
          form(action="")
            .mb-3.d-none
              label(class="form-label") Id
              input(type="text" class="form-control" name="fileId" readonly)
            .mb-3
              label(class="form-label") Tên file
              input(type="text" class="form-control" name="fileName")
            button.btn.btn-primary(type="submit") Lưu thay đổi
  //- Upload file
  .card
    .card-header
      .row.align-items-center
        .col
          h4.card-title.mb-0 Upload file
    .card-body.pt-0
      div#uppy-upload
  //- Hết upload file